<Window x:Class="Weitong.Ledger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="市场部台账管理系统" Height="920" Width="1440"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Canvas}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Shell 命令栏 -->
    <Border Grid.Row="0" Background="{StaticResource B.Shell}">
      <Grid Margin="18,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Height="52">
          <TextBlock Text="市场部台账管理系统" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Column="1" x:Name="IdentityText" VerticalAlignment="Center" HorizontalAlignment="Right"
                   Margin="0,0,18,0" Foreground="#9DB4D6" FontSize="12"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock x:Name="ClockText" VerticalAlignment="Center" Margin="0,0,14,0"
                     Foreground="#9DB4D6" FontSize="12"/>
          <Button x:Name="RefreshBtn" Content="刷新" Style="{StaticResource ToolBtn}" Click="OnRefresh"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 主体：左导航 + 内容 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="176"/><ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource B.ShellDark}">
        <StackPanel>
          <TextBlock x:Name="NavTeam" Text="行业市场组" Foreground="#7E93AE" FontSize="11" Margin="18,16,0,8"/>
          <RadioButton x:Name="NavOverview" Style="{StaticResource NavItem}" Content="达成总览" IsChecked="True" GroupName="nav" Tag="overview" Checked="OnNav"/>
          <RadioButton Style="{StaticResource NavItem}" Content="台账明细" GroupName="nav" Tag="browse" Checked="OnNav"/>
          <RadioButton Style="{StaticResource NavItem}" Content="个人录入" GroupName="nav" Tag="entry" Checked="OnNav"/>
          <RadioButton Style="{StaticResource NavItem}" Content="我的达成" GroupName="nav" Tag="mine" Checked="OnNav"/>
          <Grid>
            <RadioButton x:Name="NavPending" Style="{StaticResource NavItem}" Content="通知" GroupName="nav" Tag="pending" Checked="OnNav"/>
            <Border x:Name="PendingBadge" Background="#C5221F" CornerRadius="9" MinWidth="18" Height="18"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0" Padding="5,0"
                    IsHitTestVisible="False" Visibility="Collapsed">
              <TextBlock x:Name="PendingBadgeText" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Grid>
          <RadioButton Style="{StaticResource NavItem}" Content="系统设置" GroupName="nav" Tag="settings" Checked="OnNav"/>
        </StackPanel>
      </Border>

      <ContentControl Grid.Column="1" x:Name="ContentHost"/>
    </Grid>

    <!-- 状态栏 -->
    <Border Grid.Row="2" Background="{StaticResource B.Surface}" BorderBrush="{StaticResource B.Hairline}" BorderThickness="0,1,0,0">
      <TextBlock x:Name="StatusBar" Text="就绪" Foreground="{StaticResource B.TextSecondary}" FontSize="11.5" Margin="18,6"/>
    </Border>
  </Grid>
</Window>
