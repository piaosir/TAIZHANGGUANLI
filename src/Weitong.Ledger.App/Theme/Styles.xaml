<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dgp="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">

  <!-- ===== 企业级浅色调色板（克制、稳重、正式） ===== -->
  <Color x:Key="C.Shell">#16345A</Color>
  <Color x:Key="C.ShellDark">#112A49</Color>
  <SolidColorBrush x:Key="B.Shell"        Color="{StaticResource C.Shell}"/>
  <SolidColorBrush x:Key="B.ShellDark"    Color="{StaticResource C.ShellDark}"/>
  <SolidColorBrush x:Key="B.Canvas"       Color="#F2F3F5"/>
  <SolidColorBrush x:Key="B.Surface"      Color="#FFFFFF"/>
  <SolidColorBrush x:Key="B.Hairline"     Color="#E3E5E9"/>
  <SolidColorBrush x:Key="B.HairlineSoft" Color="#EDEEF1"/>
  <SolidColorBrush x:Key="B.TextPrimary"  Color="#1E2530"/>
  <SolidColorBrush x:Key="B.TextSecondary" Color="#5C636E"/>
  <SolidColorBrush x:Key="B.TextMuted"    Color="#8A9099"/>
  <SolidColorBrush x:Key="B.Accent"       Color="#1B5FA8"/>
  <SolidColorBrush x:Key="B.AccentSoft"   Color="#E9F0F8"/>
  <SolidColorBrush x:Key="B.NavSelBg"     Color="#22FFFFFF"/>
  <SolidColorBrush x:Key="B.HeaderRow"    Color="#F6F7F9"/>
  <SolidColorBrush x:Key="B.RowAlt"       Color="#FAFBFC"/>
  <SolidColorBrush x:Key="B.Good"         Color="#1E8E3E"/>
  <SolidColorBrush x:Key="B.GoodSoft"     Color="#E6F4EA"/>
  <SolidColorBrush x:Key="B.Warn"         Color="#B26A00"/>
  <SolidColorBrush x:Key="B.WarnSoft"     Color="#FBF0DD"/>
  <SolidColorBrush x:Key="B.Bad"          Color="#C5221F"/>
  <SolidColorBrush x:Key="B.BadSoft"      Color="#FBE9E8"/>

  <FontFamily x:Key="F.Ui">Microsoft YaHei UI, Segoe UI, sans-serif</FontFamily>
  <BooleanToVisibilityConverter x:Key="BoolToVis"/>

  <!-- ===== 卡片（细发线，微圆角，无花哨阴影） ===== -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource B.Surface}"/>
    <Setter Property="BorderBrush" Value="{StaticResource B.Hairline}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
  </Style>

  <!-- 区块标题 -->
  <Style x:Key="SectionTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="13.5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
  </Style>
  <Style x:Key="SectionHint" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Foreground" Value="{StaticResource B.TextMuted}"/>
  </Style>

  <!-- ===== 工具栏按钮（Shell 内） ===== -->
  <Style x:Key="ToolBtn" TargetType="Button">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Foreground" Value="#D8E2EF"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="Margin" Value="6,0,0,0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="3"
                  BorderBrush="#3A5578" BorderThickness="1" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
              <Setter Property="Foreground" Value="#FFFFFF"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="ToolBtnPrimary" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="Background" Value="#2C6FB5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <!-- ===== 口径切换（分段控件） ===== -->
  <Style x:Key="SegBtn" TargetType="RadioButton">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="#C4D2E4"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="12,5"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="bd" Property="Background" Value="#FFFFFF"/>
              <Setter Property="Foreground" Value="{StaticResource B.Shell}"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ===== 浅色分段控件（内容页用，如口径切换） ===== -->
  <Style x:Key="SegBtnLight" TargetType="RadioButton">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="14,6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="#00000008"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Accent}"/>
              <Setter Property="Foreground" Value="White"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ===== 左侧导航项 ===== -->
  <Style x:Key="NavItem" TargetType="RadioButton">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="#C9D4E2"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="bd" Background="Transparent" Padding="18,10" BorderThickness="3,0,0,0" BorderBrush="Transparent">
            <ContentPresenter VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="#18FFFFFF"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="bd" Property="Background" Value="#26FFFFFF"/>
              <Setter TargetName="bd" Property="BorderBrush" Value="#5B9BD5"/>
              <Setter Property="Foreground" Value="#FFFFFF"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ===== 内容区工具按钮（浅色） ===== -->
  <Style x:Key="GridToolBtn" TargetType="Button">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
    <Setter Property="Background" Value="{StaticResource B.Surface}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="Margin" Value="0,0,8,0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4"
                  BorderBrush="{StaticResource B.Hairline}" BorderThickness="1" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{StaticResource B.AccentSoft}"/>
              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="GridToolBtnPrimary" TargetType="Button" BasedOn="{StaticResource GridToolBtn}">
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="Background" Value="{StaticResource B.Accent}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <!-- ===== DataGrid（企业级：细线、浅表头、右对齐数字） ===== -->
  <Style x:Key="GridColHeader" TargetType="{x:Type dgp:DataGridColumnHeader}">
    <Setter Property="Background" Value="{StaticResource B.HeaderRow}"/>
    <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="BorderBrush" Value="{StaticResource B.Hairline}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
  </Style>

  <Style x:Key="EnterpriseGrid" TargetType="DataGrid">
    <Setter Property="FontFamily" Value="{StaticResource F.Ui}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Background" Value="{StaticResource B.Surface}"/>
    <Setter Property="RowBackground" Value="{StaticResource B.Surface}"/>
    <Setter Property="AlternatingRowBackground" Value="{StaticResource B.RowAlt}"/>
    <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
    <Setter Property="BorderBrush" Value="{StaticResource B.Hairline}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource B.HairlineSoft}"/>
    <Setter Property="HeadersVisibility" Value="Column"/>
    <Setter Property="AutoGenerateColumns" Value="False"/>
    <Setter Property="CanUserAddRows" Value="False"/>
    <Setter Property="CanUserResizeRows" Value="False"/>
    <Setter Property="IsReadOnly" Value="True"/>
    <Setter Property="RowHeight" Value="34"/>
    <Setter Property="ColumnHeaderHeight" Value="34"/>
    <Setter Property="SelectionMode" Value="Single"/>
    <Setter Property="SelectionUnit" Value="FullRow"/>
    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    <Setter Property="ColumnHeaderStyle" Value="{StaticResource GridColHeader}"/>
  </Style>

</ResourceDictionary>
