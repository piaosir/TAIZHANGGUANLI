<UserControl x:Class="Weitong.Ledger.App.Views.ColumnFilterPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource F.Ui}" Width="252">
  <UserControl.Resources>
    <!-- 弹窗内链接式小按钮 -->
    <Style x:Key="LinkBtn" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{StaticResource B.Accent}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource B.AccentSoft}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- 主操作按钮 -->
    <Style x:Key="PrimBtn" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource B.Accent}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="14,5"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Shell}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource LinkBtn}">
      <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
    </Style>
  </UserControl.Resources>

  <Border Background="{StaticResource B.Surface}" BorderBrush="{StaticResource B.Hairline}"
          BorderThickness="1" CornerRadius="7">
    <Border.Effect>
      <DropShadowEffect Color="#33000000" BlurRadius="14" ShadowDepth="2" Direction="270"/>
    </Border.Effect>
    <StackPanel>
      <!-- 标题 -->
      <TextBlock x:Name="TitleText" Margin="12,10,12,2" FontWeight="SemiBold" FontSize="12.5"
                 Foreground="{StaticResource B.TextPrimary}" TextTrimming="CharacterEllipsis"/>
      <!-- 排序 -->
      <StackPanel Orientation="Horizontal" Margin="8,2,8,6">
        <Button Content="↑ 升序排列" Style="{StaticResource LinkBtn}" Click="OnSortAsc"/>
        <Button Content="↓ 降序排列" Style="{StaticResource LinkBtn}" Click="OnSortDesc" Margin="4,0,0,0"/>
      </StackPanel>
      <Border Height="1" Background="{StaticResource B.HairlineSoft}"/>
      <!-- 搜索 -->
      <TextBox x:Name="SearchBox" Margin="10,8,10,6" Padding="6,4" TextChanged="OnSearch"
               VerticalContentAlignment="Center" ToolTip="搜索值"/>
      <!-- 全选 -->
      <CheckBox x:Name="SelectAll" Content="（全选）" Margin="13,0,10,6" IsThreeState="True"
                Click="OnSelectAll" Foreground="{StaticResource B.TextSecondary}" FontSize="12.5"/>
      <Border BorderBrush="{StaticResource B.HairlineSoft}" BorderThickness="0,1,0,1">
        <ListBox x:Name="ValueList" BorderThickness="0" MaxHeight="240" Background="Transparent"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="Transparent" Padding="13,3">
                      <ContentPresenter/>
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Content="{Binding Display}" FontSize="12.5"
                        Foreground="{StaticResource B.TextPrimary}"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
      <!-- 底部按钮 -->
      <DockPanel Margin="10,8,10,10" LastChildFill="False">
        <Button DockPanel.Dock="Left" Content="清除筛选" Style="{StaticResource GhostBtn}" Click="OnClear"/>
        <Button DockPanel.Dock="Right" Content="确定" Style="{StaticResource PrimBtn}" Click="OnOk"/>
        <Button DockPanel.Dock="Right" Content="取消" Style="{StaticResource GhostBtn}" Margin="0,0,6,0" Click="OnCancel"/>
      </DockPanel>
    </StackPanel>
  </Border>
</UserControl>
