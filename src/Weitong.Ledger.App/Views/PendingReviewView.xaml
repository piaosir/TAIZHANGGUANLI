<UserControl x:Class="Weitong.Ledger.App.Views.PendingReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Canvas}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolVis"/>
    <!-- 操作类型标签 -->
    <Style x:Key="OpTag" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource B.AccentSoft}"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="8,2"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16,18,18">
    <StackPanel>
      <TextBlock Text="通知" FontSize="18" FontWeight="Bold" Foreground="{StaticResource B.TextPrimary}"/>
      <TextBlock Style="{StaticResource SectionHint}" Margin="0,4,0,14" TextWrapping="Wrap"
                 Text="管理员对你名下数据的增删改会立即生效，这里只做通知，无需你确认。看过后点『知道了』消除提醒；标记是复核提醒，知晓后消失。"/>

      <!-- 待我知晓 -->
      <DockPanel Margin="0,0,0,8">
        <TextBlock Text="{Binding IncomingHeader}" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Visibility="{Binding HasIncoming, Converter={StaticResource BoolVis}}">
          <CheckBox x:Name="IncomingAll" Content="全选" VerticalAlignment="Center" Margin="0,0,12,0" Click="OnIncomingSelectAll"/>
          <Button Content="全部知道了" Click="OnBatchConfirm" Style="{StaticResource GridToolBtnPrimary}"/>
        </StackPanel>
      </DockPanel>

      <Border Style="{StaticResource Card}" Padding="18,16" Visibility="{Binding NoIncoming, Converter={StaticResource BoolVis}}">
        <TextBlock Text="暂无通知。管理员对你名下数据发起增删改时会出现在这里，左侧菜单也会有红点提示。"
                   Foreground="{StaticResource B.TextMuted}" FontSize="12.5" TextWrapping="Wrap"/>
      </Border>

      <ItemsControl ItemsSource="{Binding Incoming}" Visibility="{Binding HasIncoming, Converter={StaticResource BoolVis}}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                <Border Grid.Column="1" Style="{StaticResource OpTag}" Margin="0,0,12,0">
                  <TextBlock Text="{Binding OpText}" Foreground="{StaticResource B.Accent}" FontSize="12" FontWeight="SemiBold"/>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Summary}" Foreground="{StaticResource B.TextPrimary}" FontSize="13" TextWrapping="Wrap"/>
                  <TextBlock Margin="0,4,0,0" Foreground="{StaticResource B.TextMuted}" FontSize="11.5">
                    <Run Text="来自 "/><Run Text="{Binding ByName, Mode=OneWay}" FontWeight="SemiBold"/><Run Text=" · "/><Run Text="{Binding CreatedText, Mode=OneWay}"/>
                  </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                  <Button Content="查看详情" Click="OnView" Style="{StaticResource GridToolBtn}"/>
                  <Button Content="{Binding ConfirmText}" Click="OnConfirm" Style="{StaticResource GridToolBtnPrimary}"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- 我发起的（管理员） -->
      <StackPanel Margin="0,18,0,0" Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}">
        <DockPanel Margin="0,0,0,8">
          <TextBlock Text="我发起的" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                      Visibility="{Binding HasOutgoing, Converter={StaticResource BoolVis}}">
            <CheckBox x:Name="OutgoingAll" Content="全选" VerticalAlignment="Center" Margin="0,0,12,0" Click="OnOutgoingSelectAll"/>
            <Button Content="批量撤回" Click="OnBatchWithdraw" Style="{StaticResource GridToolBtn}"/>
            <Button Content="清除" Click="OnBatchClear" Style="{StaticResource GridToolBtn}"/>
          </StackPanel>
        </DockPanel>
        <Border Style="{StaticResource Card}" Padding="18,14" Visibility="{Binding NoOutgoing, Converter={StaticResource BoolVis}}">
          <TextBlock Text="你在『台账明细』对他人名下数据的改动会记录在这里，并显示对方是否已知晓。"
                     Foreground="{StaticResource B.TextMuted}" FontSize="12.5" TextWrapping="Wrap"/>
        </Border>
        <ItemsControl ItemsSource="{Binding Outgoing}" Visibility="{Binding HasOutgoing, Converter={StaticResource BoolVis}}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,8">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <Border Grid.Column="1" Style="{StaticResource OpTag}" Margin="0,0,12,0">
                    <TextBlock Text="{Binding OpText}" Foreground="{StaticResource B.Accent}" FontSize="12" FontWeight="SemiBold"/>
                  </Border>
                  <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}" Foreground="{StaticResource B.TextPrimary}" FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource B.TextMuted}" FontSize="11.5">
                      <Run Text="对「"/><Run Text="{Binding TargetOwnerName, Mode=OneWay}" FontWeight="SemiBold"/><Run Text="」 · "/><Run Text="{Binding StatusText, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding CreatedText, Mode=OneWay}"/>
                    </TextBlock>
                    <!-- 驳回留言：对方驳回时填的理由，回流后在此显示 -->
                    <Border Margin="0,6,0,0" Background="{StaticResource B.BadSoft}" CornerRadius="3" Padding="8,5"
                            HorizontalAlignment="Left" Visibility="{Binding HasRejectNote, Converter={StaticResource BoolVis}}">
                      <TextBlock Foreground="{StaticResource B.Bad}" FontSize="12" TextWrapping="Wrap">
                        <Run Text="驳回留言：" FontWeight="SemiBold"/><Run Text="{Binding DecideNote, Mode=OneWay}"/>
                      </TextBlock>
                    </Border>
                  </StackPanel>
                  <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="查看" Click="OnViewOutgoing" Style="{StaticResource GridToolBtn}"/>
                    <Button Content="撤回" Click="OnWithdraw" Style="{StaticResource GridToolBtn}"
                            Visibility="{Binding CanWithdraw, Converter={StaticResource BoolVis}}"/>
                    <Button Content="清除" Click="OnClearOne" Style="{StaticResource GridToolBtn}"
                            Visibility="{Binding CanClear, Converter={StaticResource BoolVis}}"/>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
