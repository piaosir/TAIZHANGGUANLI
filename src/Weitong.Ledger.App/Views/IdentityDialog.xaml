<Window x:Class="Weitong.Ledger.App.Views.IdentityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="身份确认" Height="340" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Surface}">
  <Grid Margin="26,22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="欢迎使用 · 请确认你的身份" FontSize="17" FontWeight="Bold"
               Foreground="{StaticResource B.TextPrimary}"/>
    <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,8,0,18" Foreground="{StaticResource B.TextSecondary}" FontSize="12.5"
               Text="本软件用这台电脑的机器码识别你的身份，无需登录。确认一次即可，之后自动识别。你的台账数据只归属到你名下。"/>

    <StackPanel Grid.Row="2" Margin="0,0,0,12">
      <TextBlock Text="姓名" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
      <TextBox x:Name="NameBox" Padding="8,6" FontSize="13"/>
    </StackPanel>
    <StackPanel Grid.Row="3">
      <TextBlock Text="团队" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
      <TextBox x:Name="TeamBox" Padding="8,6" FontSize="13" Text="行业市场组"/>
    </StackPanel>

    <TextBlock Grid.Row="4" x:Name="MachineText" VerticalAlignment="Bottom"
               Foreground="{StaticResource B.TextMuted}" FontSize="11.5" Margin="0,14,0,0"/>

    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="取消" Width="80" Height="32" Margin="0,0,10,0" Click="OnCancel"/>
      <Button Content="确认并进入" Width="120" Height="32" Click="OnOk"
              Background="{StaticResource B.Accent}" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
    </StackPanel>
  </Grid>
</Window>
