<Window x:Class="Weitong.Ledger.App.Views.TextPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="请输入" Height="240" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Surface}">
  <Grid Margin="22,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" x:Name="TitleText" FontSize="15" FontWeight="Bold"
               Foreground="{StaticResource B.TextPrimary}"/>
    <TextBlock Grid.Row="1" x:Name="HintText" Margin="0,6,0,10" TextWrapping="Wrap"
               Foreground="{StaticResource B.TextSecondary}" FontSize="12"/>

    <TextBox Grid.Row="2" x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto" Padding="8,6" FontSize="13"
             VerticalContentAlignment="Top"/>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="取消" Width="80" Height="32" Margin="0,0,10,0" Click="OnCancel"/>
      <Button Content="确定" Width="100" Height="32" Click="OnOk"
              Background="{StaticResource B.Accent}" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
    </StackPanel>
  </Grid>
</Window>
