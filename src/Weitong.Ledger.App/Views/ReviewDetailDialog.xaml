<Window x:Class="Weitong.Ledger.App.Views.ReviewDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="内容详情" Height="640" Width="720"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Canvas}">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolVis"/>
    <Style x:Key="Val" TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap"/><Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
    </Style>
  </Window.Resources>

  <Grid Margin="22,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="17" FontWeight="Bold" Foreground="{StaticResource B.TextPrimary}"/>
    <TextBlock Grid.Row="1" Text="{Binding Subtitle}" Margin="0,4,0,0" Foreground="{StaticResource B.TextSecondary}" FontSize="13"/>

    <Border Grid.Row="2" Background="{StaticResource B.AccentSoft}" CornerRadius="4" Padding="10,7" Margin="0,10,0,10">
      <TextBlock Text="{Binding Banner}" Foreground="{StaticResource B.Accent}" FontSize="12" TextWrapping="Wrap"/>
    </Border>

    <Border Grid.Row="3" Style="{StaticResource Card}">
      <DataGrid x:Name="Grid" ItemsSource="{Binding Rows}" Style="{StaticResource EnterpriseGrid}"
                IsReadOnly="True" HeadersVisibility="Column" Margin="1">
        <DataGrid.RowStyle>
          <Style TargetType="{x:Type DataGridRow}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding Changed}" Value="True">
                <Setter Property="Background" Value="{StaticResource B.BadSoft}"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <DataGridTextColumn Header="字段" Binding="{Binding Field}" Width="130"/>
          <DataGridTextColumn Header="现值" Binding="{Binding Current}" Width="*"/>
          <DataGridTextColumn x:Name="ProposedCol" Header="提案值（管理员）" Binding="{Binding Proposed}" Width="*">
            <DataGridTextColumn.CellStyle>
              <Style TargetType="{x:Type DataGridCell}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Changed}" Value="True">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="{StaticResource B.Bad}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridTextColumn.CellStyle>
          </DataGridTextColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button x:Name="ConfirmBtn" Content="{Binding ConfirmText}" Click="OnConfirm" MinWidth="110" Height="34" Margin="0,0,10,0"
              Background="{StaticResource B.Accent}" Foreground="White" FontWeight="SemiBold" BorderThickness="0"
              Visibility="{Binding IsIncoming, Converter={StaticResource BoolVis}}"/>
      <Button Content="关闭" Click="OnClose" MinWidth="90" Height="34"/>
    </StackPanel>
  </Grid>
</Window>
