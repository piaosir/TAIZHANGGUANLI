<UserControl x:Class="Weitong.Ledger.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Canvas}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16,18,18">
    <StackPanel MaxWidth="640" HorizontalAlignment="Left">
      <TextBlock Text="系统设置" FontSize="18" FontWeight="Bold" Foreground="{StaticResource B.TextPrimary}"/>
      <TextBlock Style="{StaticResource SectionHint}" Margin="0,4,0,14"
                 Text="身份与本机信息。你可以随时在自己的电脑上修改姓名（支持重名——身份由机器码唯一区分，姓名只作显示）。"/>

      <Border Style="{StaticResource Card}" Padding="18,16">
        <StackPanel>
          <TextBlock Text="我的身份" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

          <TextBlock Text="姓名" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
          <TextBox x:Name="NameBox" Padding="8,6" FontSize="13" Width="280" HorizontalAlignment="Left"/>

          <TextBlock Text="团队" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,12,0,4"/>
          <TextBox x:Name="TeamBox" Padding="8,6" FontSize="13" Width="280" HorizontalAlignment="Left"/>

          <Button Content="保存" Click="OnSave" Style="{StaticResource GridToolBtnPrimary}" HorizontalAlignment="Left" Margin="0,16,0,0"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,14,0,0">
        <StackPanel>
          <TextBlock Text="数据与安全" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
          <TextBlock x:Name="DataInfo" Style="{StaticResource SectionHint}" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
