<Window x:Class="Weitong.Ledger.App.Views.TeamTargetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="团队年度目标" Height="440" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Surface}">
  <Grid Margin="26,22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" x:Name="TitleText" Text="设定团队年度目标" FontSize="17" FontWeight="Bold"
               Foreground="{StaticResource B.TextPrimary}"/>
    <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,8,0,16" Foreground="{StaticResource B.TextSecondary}" FontSize="12.5"
               Text="用于总览看板的收入达成、利润达成、成本控制、累计到款进度。单位：万元。可手动填写，或从「本部各领域填报表单」一键导入。"/>

    <!-- 三条线指标 -->
    <StackPanel Grid.Row="2" Orientation="Horizontal">
      <StackPanel Margin="0,0,18,0">
        <TextBlock Text="收入指标" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="RevBox" Width="150" Padding="8,6" FontSize="13"/>
      </StackPanel>
      <StackPanel Margin="0,0,18,0">
        <TextBlock Text="利润指标" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="ProfitBox" Width="150" Padding="8,6" FontSize="13"/>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="成本控制指标（上限）" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="CostBox" Width="150" Padding="8,6" FontSize="13"/>
      </StackPanel>
    </StackPanel>

    <!-- 从 Excel 导入 -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
      <Button Content="从填报表单 Excel 导入…" Click="OnImport" Height="32" Padding="12,0"
              Background="{StaticResource B.Surface}" BorderBrush="{StaticResource B.Hairline}" BorderThickness="1"/>
      <StackPanel x:Name="TeamPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="14,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="对应团队" Foreground="{StaticResource B.TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <ComboBox x:Name="TeamCombo" Width="240" Height="30" SelectionChanged="OnTeamChanged"/>
      </StackPanel>
    </StackPanel>

    <TextBlock Grid.Row="4" x:Name="ImportInfo" TextWrapping="Wrap" Margin="0,10,0,0"
               Foreground="{StaticResource B.TextMuted}" FontSize="11.5"/>

    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="取消" Width="80" Height="32" Margin="0,0,10,0" Click="OnCancel"/>
      <Button x:Name="SaveBtn" Content="保存并同步" Width="130" Height="32" Click="OnSave"
              Background="{StaticResource B.Accent}" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
    </StackPanel>
  </Grid>
</Window>
