<UserControl x:Class="Weitong.Ledger.App.Views.LedgerGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Weitong.Ledger.App.ViewModels"
             xmlns:views="clr-namespace:Weitong.Ledger.App.Views"
             FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Canvas}">
  <UserControl.Resources>
    <Style x:Key="NumCell" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>
    <Style x:Key="NumEdit" TargetType="TextBox">
      <Setter Property="HorizontalContentAlignment" Value="Right"/>
    </Style>
  </UserControl.Resources>

  <Grid Margin="18,14,18,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 标题 -->
    <StackPanel Grid.Row="0" Margin="0,0,0,10">
      <TextBlock Text="个人录入 · 我的台账" FontSize="18" FontWeight="Bold" Foreground="{StaticResource B.TextPrimary}"/>
      <TextBlock Text="只显示你名下的合同。像 Excel 一样录入：整块粘贴(Ctrl+V)、向下填充(Ctrl+D)、下拉选择、利润 U=收入−成本 实时计算、非法值红框。改完自动保存进总库，无需手动保存。金额单位：元。"
                 Style="{StaticResource SectionHint}" Margin="0,4,0,0" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- 工具栏 -->
    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10,8" Margin="0,0,0,10">
      <DockPanel LastChildFill="False">
        <Button DockPanel.Dock="Left" Content="＋ 新增行" Click="OnAdd" Style="{StaticResource GridToolBtnPrimary}"/>
        <Button DockPanel.Dock="Left" Content="删除选中" Click="OnDelete" Style="{StaticResource GridToolBtn}"/>
        <Separator DockPanel.Dock="Left" Margin="4,4" Background="{StaticResource B.Hairline}"/>
        <Button DockPanel.Dock="Left" Content="↶ 撤销" Click="OnUndo" IsEnabled="{Binding CanUndo}" Style="{StaticResource GridToolBtn}" ToolTip="Ctrl+Z"/>
        <Button DockPanel.Dock="Left" Content="↷ 重做" Click="OnRedo" IsEnabled="{Binding CanRedo}" Style="{StaticResource GridToolBtn}" ToolTip="Ctrl+Y"/>
        <Separator DockPanel.Dock="Left" Margin="4,4" Background="{StaticResource B.Hairline}"/>
        <Button DockPanel.Dock="Left" Content="导出 Excel" Click="OnExport" Style="{StaticResource GridToolBtn}"/>

        <TextBox DockPanel.Dock="Right" Width="220" VerticalAlignment="Center" Padding="6,4"
                 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                 ToolTip="全字段搜索"/>
        <TextBlock DockPanel.Dock="Right" Text="搜索" VerticalAlignment="Center" Foreground="{StaticResource B.TextMuted}" Margin="0,0,8,0"/>
      </DockPanel>
    </Border>

    <!-- 录入网格 -->
    <Border Grid.Row="2" Style="{StaticResource Card}">
      <DataGrid x:Name="Grid" ItemsSource="{Binding View}" Style="{StaticResource EnterpriseGrid}"
                IsReadOnly="False" CanUserAddRows="False" SelectionUnit="CellOrRowHeader" SelectionMode="Extended"
                HorizontalScrollBarVisibility="Auto" ClipboardCopyMode="ExcludeHeader"
                views:GridExcel.EnableExcel="True" RowEditEnding="OnRowEdited" Margin="1">
        <DataGrid.Columns>
          <DataGridComboBoxColumn Header="合同层级" SelectedItemBinding="{Binding StageName}"
                                  ItemsSource="{x:Static vm:ContractRow.StageOptions}" Width="90"/>
          <DataGridTextColumn Header="合同编号" Width="150"
                              Binding="{Binding ContractNo, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="项目名称" Width="180"
                              Binding="{Binding ProjectName, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="合同甲方" Width="200" Binding="{Binding PartyA, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="销售人员" Width="90" Binding="{Binding SalesPersonName, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="市场领域" Width="110" Binding="{Binding MarketField, UpdateSourceTrigger=LostFocus}"/>
          <DataGridComboBoxColumn Header="产品类型" SelectedItemBinding="{Binding ProductType}"
                                  ItemsSource="{x:Static vm:ContractRow.ProductOptions}" Width="90"/>
          <DataGridComboBoxColumn Header="项目属性" SelectedItemBinding="{Binding ProjectAttribute}"
                                  ItemsSource="{x:Static vm:ContractRow.AttributeOptions}" Width="120"/>
          <DataGridTextColumn Header="币种" Width="70" Binding="{Binding Currency, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="合同金额" Width="120" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding ContractAmount, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="本年收入" Width="120" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Revenue, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="本年成本" Width="120" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Cost, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="本年利润 U" Width="120" IsReadOnly="True" ElementStyle="{StaticResource NumCell}"
                              Binding="{Binding Profit, StringFormat=N2}"/>
          <DataGridTextColumn Header="1-4月到款" Width="100" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay1to4, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="5月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay5, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="6月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay6, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="7月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay7, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="8月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay8, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="9月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay9, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="10月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay10, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="11月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay11, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="12月" Width="90" ElementStyle="{StaticResource NumCell}" EditingElementStyle="{StaticResource NumEdit}"
                              Binding="{Binding Pay12, StringFormat=N2, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="预计到款 V" Width="120" IsReadOnly="True" ElementStyle="{StaticResource NumCell}"
                              Binding="{Binding PaymentTotal, StringFormat=N2}"/>
          <DataGridTextColumn Header="签约日期" Width="110"
                              Binding="{Binding SignDateText, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=LostFocus}"/>
          <DataGridTextColumn Header="培育来源" Width="160" Binding="{Binding CultivationSource, UpdateSourceTrigger=LostFocus}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- 状态栏 -->
    <TextBlock Grid.Row="3" Text="{Binding StatusText}" Margin="2,8,0,0"
               Foreground="{StaticResource B.TextSecondary}" FontSize="12"/>
  </Grid>
</UserControl>
