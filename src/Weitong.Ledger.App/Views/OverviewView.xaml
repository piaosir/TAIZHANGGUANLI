<UserControl x:Class="Weitong.Ledger.App.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             FontFamily="{StaticResource F.Ui}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16,18,18">
    <StackPanel>
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="达成怎么算" Foreground="{StaticResource B.TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <Border Background="#EEF1F5" CornerRadius="5" BorderBrush="{StaticResource B.Hairline}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
              <RadioButton Style="{StaticResource SegBtnLight}" Content="只算已签约" GroupName="basisov"
                           IsChecked="{Binding IsStrict, Mode=TwoWay}" ToolTip="只把已经签约的合同算进达成，最保守、最实"/>
              <RadioButton Style="{StaticResource SegBtnLight}" Content="含在谈预测" GroupName="basisov"
                           IsChecked="{Binding IsWeighted, Mode=TwoWay}" ToolTip="把在谈的项目按成交概率折算后一起算，用于预测能不能完成"/>
            </StackPanel>
          </Border>
          <Button Content="目标设置" x:Name="EditTargetBtn" Visibility="Collapsed"
                  Style="{StaticResource GridToolBtn}" Margin="12,0,0,0" Click="OnEditTarget"
                  ToolTip="设定 / 从填报表单 Excel 导入本团队的年度收入、利润、成本控制指标（管理员，保存后自动同步全组）"/>
          <Button Content="导出详细报告" Style="{StaticResource GridToolBtnPrimary}" Margin="8,0,0,0"
                  Click="OnExportReport" ToolTip="把本页全部内容（市场策划进展、KPI、按销售明细、漏斗、月度到款、销售×层级、数据质量）导出为分 sheet 的 Excel 详细报告"/>
        </StackPanel>
        <TextBlock Text="{Binding TeamName, StringFormat={}{0} · 目标达成总览}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource B.TextPrimary}"/>
      </DockPanel>
      <TextBlock Text="{Binding MetaText}" Style="{StaticResource SectionHint}" Margin="0,4,0,14"/>

      <!-- KPI 行 -->
      <ItemsControl ItemsSource="{Binding Kpis}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="16,13">
              <StackPanel>
                <DockPanel>
                  <TextBlock Text="{Binding Title}" Foreground="{StaticResource B.TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock Text="{Binding RateText}" FontSize="29" FontWeight="Bold"
                           Foreground="{StaticResource B.TextPrimary}" Margin="0,7,0,2"/>
                <TextBlock Text="{Binding ValueText}" Foreground="{StaticResource B.TextSecondary}" FontSize="11.5"/>
                <TextBlock Text="{Binding GapText}" Foreground="{Binding StatusBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,5,0,0"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- 目标达成明细矩阵 -->
      <Border Style="{StaticResource Card}" Margin="0,14,0,0">
        <StackPanel>
          <StackPanel Margin="16,13,16,10">
            <TextBlock Text="目标达成明细（按销售）" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="金额单位：万元 · 收入/利润为已签约口径 · 加权收入为预测口径 · 占比=已签约收入占全组"
                       Style="{StaticResource SectionHint}" Margin="0,3,0,0"/>
          </StackPanel>
          <DataGrid ItemsSource="{Binding Achievements}" Style="{StaticResource EnterpriseGrid}" Margin="1,0,1,1">
            <DataGrid.Resources>
              <Style x:Key="Num" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Margin" Value="0,0,14,0"/>
              </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
              <DataGridTextColumn Header="销售人员" Binding="{Binding Name}" Width="1.4*"/>
              <DataGridTextColumn Header="合同数" Binding="{Binding Count}" Width="*" ElementStyle="{StaticResource Num}"/>
              <DataGridTextColumn Header="已签约收入" Binding="{Binding SignedRevenue, StringFormat=N0}" Width="1.2*" ElementStyle="{StaticResource Num}"/>
              <DataGridTextColumn Header="已签约利润" Binding="{Binding SignedProfit, StringFormat=N0}" Width="1.2*" ElementStyle="{StaticResource Num}"/>
              <DataGridTextColumn Header="加权收入(预测)" Binding="{Binding Weighted, StringFormat=N0}" Width="1.3*" ElementStyle="{StaticResource Num}"/>
              <DataGridTextColumn Header="本年预计到款" Binding="{Binding Payment, StringFormat=N0}" Width="1.3*" ElementStyle="{StaticResource Num}"/>
              <DataGridTextColumn Header="占全组收入" Binding="{Binding SharePct, StringFormat={}{0:N1}%}" Width="*" ElementStyle="{StaticResource Num}"/>
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
      </Border>

      <!-- 图表：排行 + 层级 -->
      <Grid Margin="0,14,0,0">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,7,0" Padding="16,13">
          <StackPanel>
            <TextBlock Text="销售完成率排行" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="当前口径收入（万元）" Style="{StaticResource SectionHint}" Margin="0,3,0,8"/>
            <lvc:CartesianChart Height="270" Series="{Binding RankSeries}" XAxes="{Binding RankX}" YAxes="{Binding RankY}"
                                LegendPosition="Hidden" TooltipPosition="Top"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,0" Padding="16,13">
          <StackPanel>
            <TextBlock Text="合同层级分布" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="各层级预计收入（万元）与笔数" Style="{StaticResource SectionHint}" Margin="0,3,0,8"/>
            <lvc:CartesianChart Height="270" Series="{Binding FunnelSeries}" XAxes="{Binding FunnelX}" YAxes="{Binding FunnelY}"
                                LegendPosition="Hidden" TooltipPosition="Top"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- 图表：月度 + 堆叠 -->
      <Grid Margin="0,14,0,0">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,7,0" Padding="16,13">
          <StackPanel>
            <TextBlock Text="1–12 月预计到款" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="柱=本期到款，线=累计到款（万元）" Style="{StaticResource SectionHint}" Margin="0,3,0,8"/>
            <lvc:CartesianChart Height="260" Series="{Binding MonthlySeries}" XAxes="{Binding MonthlyX}" YAxes="{Binding MonthlyY}"
                                LegendPosition="Bottom" TooltipPosition="Top"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,0" Padding="16,13">
          <StackPanel>
            <TextBlock Text="销售 × 合同层级" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="各销售预计收入按层级堆叠（万元）" Style="{StaticResource SectionHint}" Margin="0,3,0,8"/>
            <lvc:CartesianChart Height="260" Series="{Binding StackSeries}" XAxes="{Binding StackX}" YAxes="{Binding StackY}"
                                LegendPosition="Bottom" TooltipPosition="Top"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- 数据质量 -->
      <Border Style="{StaticResource Card}" Margin="0,14,0,0" Padding="16,13">
        <StackPanel>
          <TextBlock Text="数据质量提示" Style="{StaticResource SectionTitle}"/>
          <TextBlock Text="软件自动捕获的需人工核对项（如 预计到款 ≠ 月度之和、金额异常），Excel 中不易发现。"
                     Style="{StaticResource SectionHint}" Margin="0,3,0,8"/>
          <DataGrid ItemsSource="{Binding Anomalies}" Style="{StaticResource EnterpriseGrid}" MaxHeight="220">
            <DataGrid.Columns>
              <DataGridTextColumn Header="工作表" Binding="{Binding Sheet}" Width="1.4*"/>
              <DataGridTextColumn Header="行" Binding="{Binding Row}" Width="0.5*"/>
              <DataGridTextColumn Header="字段" Binding="{Binding Field}" Width="1.2*"/>
              <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="1.3*"/>
              <DataGridTextColumn Header="提示" Binding="{Binding Reason}" Width="3*"/>
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
