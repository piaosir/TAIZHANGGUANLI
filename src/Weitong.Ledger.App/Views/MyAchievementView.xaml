<UserControl x:Class="Weitong.Ledger.App.Views.MyAchievementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             FontFamily="{StaticResource F.Ui}" Background="{StaticResource B.Canvas}">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16,18,18">
    <StackPanel>
      <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource B.TextPrimary}"/>
      <TextBlock Text="{Binding Summary}" Style="{StaticResource SectionHint}" Margin="0,4,0,14"/>

      <!-- 我的目标 -->
      <Border Style="{StaticResource Card}" Padding="18,14" Margin="0,0,0,14">
        <StackPanel>
          <TextBlock Text="我的目标（万元）" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
          <StackPanel Orientation="Horizontal">
            <StackPanel Margin="0,0,20,0">
              <TextBlock Text="收入指标" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
              <TextBox Width="130" Padding="7,5" FontSize="13" Text="{Binding RevenueTargetWan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}"/>
            </StackPanel>
            <StackPanel Margin="0,0,20,0">
              <TextBlock Text="利润指标" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
              <TextBox Width="130" Padding="7,5" FontSize="13" Text="{Binding ProfitTargetWan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}"/>
            </StackPanel>
            <StackPanel Margin="0,0,20,0">
              <TextBlock Text="成本控制指标（上限）" Foreground="{StaticResource B.TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
              <TextBox Width="130" Padding="7,5" FontSize="13" Text="{Binding CostTargetWan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}"/>
            </StackPanel>
            <Button Content="保存目标" Click="OnSaveTarget" Style="{StaticResource GridToolBtnPrimary}" VerticalAlignment="Bottom"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- KPI -->
      <ItemsControl ItemsSource="{Binding Dash.Kpis}">
        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Padding="16,13">
              <StackPanel>
                <DockPanel>
                  <TextBlock Text="{Binding Title}" Foreground="{StaticResource B.TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock Text="{Binding RateText}" FontSize="29" FontWeight="Bold" Foreground="{StaticResource B.TextPrimary}" Margin="0,7,0,2"/>
                <TextBlock Text="{Binding ValueText}" Foreground="{StaticResource B.TextSecondary}" FontSize="11.5"/>
                <TextBlock Text="{Binding GapText}" Foreground="{Binding StatusBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,5,0,0"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- 图表：个人漏斗 + 个人月度到款 -->
      <Grid Margin="0,14,0,0">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,7,0" Padding="16,13">
          <StackPanel>
            <TextBlock Text="我的合同层级分布" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="各层级预计收入（万元）与笔数" Style="{StaticResource SectionHint}" Margin="0,3,0,8"/>
            <lvc:CartesianChart Height="270" Series="{Binding Dash.FunnelSeries}" XAxes="{Binding Dash.FunnelX}" YAxes="{Binding Dash.FunnelY}"
                                LegendPosition="Hidden" TooltipPosition="Top"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,0" Padding="16,13">
          <StackPanel>
            <TextBlock Text="我的 1–12 月到款" Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="柱=本期到款，线=累计到款（万元）" Style="{StaticResource SectionHint}" Margin="0,3,0,8"/>
            <lvc:CartesianChart Height="270" Series="{Binding Dash.MonthlySeries}" XAxes="{Binding Dash.MonthlyX}" YAxes="{Binding Dash.MonthlyY}"
                                LegendPosition="Bottom" TooltipPosition="Top"/>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
